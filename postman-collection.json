    {
      "name": "Complete Order Flow with Saga",
      "item": [
        {
          "name": "1. Create Product",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/products",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test Laptop\",\n  \"description\": \"High-performance laptop for testing\",\n  \"price\": 1299.99,\n  \"category\": \"Electronics\",\n  \"tags\": [\"laptop\", \"computer\", \"test\"],\n  \"imageUrl\": \"https://example.com/laptop.jpg\"\n}"
            }
          },
          "description": "Step 1: Create a product - this will trigger events to Search Service and Inventory Service"
        },
        {
          "name": "2. Create Inventory for Product",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/inventory",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productId\": \"{{productId}}\",\n  \"quantity\": 100,\n  \"location\": \"warehouse-1\",\n  \"reservedQuantity\": 0\n}"
            }
          },
          "description": "Step 2: Create inventory record for the product (replace {{productId}} with actual product ID from step 1)"
        },
        {
          "name": "3. Add Item to Cart",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/cart/{{userId}}/items",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productId\": \"{{productId}}\",\n  \"productName\": \"iPhone 15 Pro\",\n  \"price\": 999.99,\n  \"quantity\": 1,\n  \"imageUrl\": \"https://example.com/iphone15.jpg\"\n}"
            }
          },
          "description": "Step 3: Add product to cart (replace {{productId}} with actual product ID from step 1)"
        },
        {
          "name": "4. Get Cart",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/cart/{{userId}}"
          },
          "description": "Step 4: Verify cart contents"
        },
        {
          "name": "5. Create Order with Saga",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/orders/with-saga",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"{{userId}}\",\n  \"items\": [\n    {\n      \"productId\": \"{{productId}}\",\n      \"productName\": \"Test Laptop\",\n      \"price\": 1299.99,\n      \"quantity\": 2,\n      \"imageUrl\": \"https://example.com/laptop.jpg\"\n    }\n  ],\n  \"shippingAddress\": \"123 Main St, City, Country\",\n  \"billingAddress\": \"123 Main St, City, Country\"\n}"
            }
          },
          "description": "Step 5: Create order with Saga pattern - this triggers: inventory reservation → payment → confirmation → notification"
        },
        {
          "name": "6. Get Order Status",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/orders/{{orderNumber}}"
          },
          "description": "Step 6: Check order status (replace {{orderNumber}} with actual order number from step 5)"
        },
        {
          "name": "7. Get Saga Status",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/orders/{{orderNumber}}/saga"
          },
          "description": "Step 7: Check Saga transaction status (replace {{orderNumber}} with actual order number from step 5)"
        },
        {
          "name": "8. Check Inventory Reservation",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/inventory/products/{{productId}}"
          },
          "description": "Step 8: Verify inventory was reserved (replace {{productId}} with actual product ID)"
        },
        {
          "name": "9. Get Reserved Items by Order",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/inventory/reserved/orders/{{orderId}}"
          },
          "description": "Step 9: Check reserved items for this order (replace {{orderId}} with actual order ID)"
        },
        {
          "name": "10. Clear Cart",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/api/cart/{{userId}}/clear"
          },
          "description": "Step 10: Clear cart after successful order"
        }
      ]
    },
