        },
        {
          "name": "6. Verify Inventory Released",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/inventory/products/{{productId}}"
          },
          "description": "Step 6: Verify inventory was released back to available stock"
        },
